# cinterop definition for the vendored Lua 5.5 + shim.
#
# The section below the --- separator is compiled by cinterop with the
# target's own clang/sysroot and packed into the klib, so every Kotlin/Native
# target carries its own build of the identical vendored sources and
# consumers need no extra linker setup. Function-like macros in the Lua API
# are not bindable; the kl_* shim wrappers in lua_shim.h cover the ones the
# binding uses.
package = com.seanproctor.lua.cinterop
headers = lua.h lauxlib.h lualib.h lua_shim.h
headerFilter = lua.h lauxlib.h lualib.h luaconf.h lua_shim.h

compilerOpts = -O2
compilerOpts.linux_x64 = -DLUA_USE_LINUX
compilerOpts.macos_arm64 = -DLUA_USE_MACOSX
compilerOpts.macos_x64 = -DLUA_USE_MACOSX
compilerOpts.ios_arm64 = -DLUA_USE_IOS
compilerOpts.ios_simulator_arm64 = -DLUA_USE_IOS

linkerOpts.linux_x64 = -lm -ldl

---

#include "lua_all.c"
#include "lua_shim.c"
